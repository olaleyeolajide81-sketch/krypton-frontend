# URL of the Krypton ZK backend (must expose POST /api/prove-factoring)
# Required — the app will fall back to http://localhost:3001 if unset, but set this explicitly in production.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Stellar network to target: "public" (mainnet) or "testnet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet
